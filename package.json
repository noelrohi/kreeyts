{
  "name": "assetwell",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "@tabler/icons-react": "^3.44.0",
      "@tailwindcss/vite": "^4.1.18",
      "@tanstack/react-router": "1.170.16",
      "@tanstack/react-start": "1.168.26",
      "@tanstack/router-cli": "1.167.17",
      "@types/bun": "^1.3.14",
      "@vitejs/plugin-react": "4.7.0",
      "class-variance-authority": "^0.7.1",
      "clsx": "^2.1.1",
      "radix-ui": "^1.4.3",
      "tailwind-merge": "^3.4.0",
      "tailwindcss": "^4.1.18",
      "tw-animate-css": "^1.4.0",
      "typescript": "^5",
      "vite": "^7.0.4"
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:desktop": "turbo dev --filter=@assetwell/desktop",
    "dev:www": "turbo dev --filter=@assetwell/www",
    "electron:dev": "bun run --cwd apps/desktop dev",
    "electron:dist": "bun run --cwd apps/desktop dist",
    "build": "turbo build",
    "build:desktop": "turbo build --filter=@assetwell/desktop",
    "build:www": "turbo build --filter=@assetwell/www",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.7.3"
  },
  "packageManager": "bun@1.2.14"
}
