{
  "name": "@assetwell/desktop",
  "private": true,
  "version": "0.0.1",
  "description": "Assetwell desktop app.",
  "author": "Rohi <noelrohi59@gmail.com>",
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "bun run prepare:higgsfield-cli && bun scripts/dev-electron.mjs",
    "dev:electron": "bun run prepare:higgsfield-cli && bun scripts/dev-electron.mjs",
    "dev:renderer": "vite",
    "prepare:higgsfield-cli": "bun scripts/ensure-higgsfield-cli.mjs",
    "build": "bun run prepare:higgsfield-cli && tsc && vite build && tsdown",
    "build:electron": "bun run prepare:higgsfield-cli && tsdown",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "dist": "bun run build && electron-builder",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.rohi.assetwell",
    "productName": "Assetwell",
    "copyright": "Copyright © 2026 Rohi",
    "directories": {
      "output": "release/electron"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/@higgsfield/cli/**/*",
      "node_modules/ffmpeg-static/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/@higgsfield/cli/vendor/**",
      "node_modules/ffmpeg-static/ffmpeg*"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "noelrohi",
        "repo": "assetwell"
      }
    ]
  },
  "dependencies": {
    "@fontsource-variable/fraunces": "^5.2.9",
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@higgsfield/cli": "0.2.3",
    "@assetwell/desktop-bridge": "workspace:*",
    "@assetwell/ui": "workspace:*",
    "@tabler/icons-react": "catalog:",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-router": "^1.170.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "catalog:",
    "cmdk": "^1.1.1",
    "electron-updater": "^6.8.3",
    "fflate": "^0.8.3",
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^1.21.0",
    "next-themes": "^0.4.6",
    "nuqs": "^2.8.9",
    "radix-ui": "^1.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-grab": "^0.1.47",
    "sonner": "^2.0.7",
    "tailwind-merge": "catalog:",
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.0.2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "electron": "42.5.0",
    "electron-builder": "^26.8.1",
    "tsdown": "^0.21.9",
    "tw-animate-css": "catalog:",
    "typescript": "catalog:",
    "vite": "^7.0.4"
  }
}
