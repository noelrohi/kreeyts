{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "VITE_DEV_SERVER_URL",
    "VITE_DEV_SERVER_HOST",
    "VITE_PORT",
    "VITE_SITE_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "test": {
      "dependsOn": ["^test"],
      "outputs": [],
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "clean": {
      "cache": false
    }
  }
}
